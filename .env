# 应用基本信息
VERSION=0.1.0
APP_TITLE=Vue FastAPI Admin
PROJECT_NAME=Vue FastAPI Admin
APP_DESCRIPTION=Description

# 服务器配置
HOST=0.0.0.0
PORT=9990

# CORS 设置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 调试模式
DEBUG=true
TEST_DATABASE_URL="postgres://username:password@localhost:5432/test_db"

# 安全设置
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# 数据库配置
DB_ENGINE=asyncpg
DB_HOST=127.0.0.1
DB_PORT=15432
DB_USER=username
DB_PASSWORD=password
DB_NAME=school_db_test_01

# 时区设置
USE_TZ=false
TIMEZONE=Asia/Shanghai
DATETIME_FORMAT=%Y-%m-%d %H:%M:%S